@using IrrigationSystem.Web.Models
@using IrrigationSystem.Web.Services
@using Microsoft.Extensions.Options
@page "/settings"
@layout MainLayout
@inject SensorDataService DataService
@inject AdaptiveWateringService AdaptiveService
@inject DemoModeService DemoService
@inject AiApiHealthService AiApiHealth
@inject OpenAiApiKeyProvider ApiKeyProvider
@inject IOptions<AiIrrigationOptions> AiDefaults
@implements IDisposable

<PageTitle>Settings - Irrigation System</PageTitle>

<div class="settings-page">
    <h3>System Settings</h3>

    @if (SystemConfig == null)
    {
        <p>Loading settings...</p>
    }
    else
    {
        <div class="settings-section">
            <h4>System Control</h4>
            
            <div class="settings-grid">
                <div class="setting-item">
                    <label class="toggle-label">
                        <input type="checkbox" @bind="SystemConfig.AutoWateringEnabled" @bind:after="SaveSettingsImmediate" class="toggle-input" />
                        <span class="toggle-slider-sm"></span>
                        <span class="toggle-text">Automatic Watering</span>
                    </label>
                    <small>Enable or disable automatic watering based on moisture levels</small>
                </div>

                <div class="setting-item">
                    <label>Default Watering Duration (seconds)</label>
                    <input type="number" min="5" max="60" @bind="SystemConfig.DefaultWateringDuration" @bind:after="SaveSettings" class="form-input" />
                    <small>How long to water each zone (5-60 seconds)</small>
                </div>
            </div>
        </div>

        <div class="settings-section">
            <h4>Night Mode Schedule</h4>
            <p>Restrict watering to nighttime hours to reduce evaporation</p>
            
            <div class="settings-grid">
                <div class="setting-item">
                    <label class="toggle-label">
                        <input type="checkbox" @bind="SystemConfig.NightModeEnabled" @bind:after="SaveSettingsImmediate" class="toggle-input" />
                        <span class="toggle-slider-sm"></span>
                        <span class="toggle-text">Enable Night Mode</span>
                    </label>
                    <small>Only water during specified hours</small>
                </div>

                @if (SystemConfig.NightModeEnabled)
                {
                    <div class="setting-item">
                        <label>Start Hour (24h format)</label>
                        <input type="number" min="0" max="23" @bind="SystemConfig.NightModeStartHour" @bind:after="SaveSettings" class="form-input" />
                        <small>Watering allowed from @SystemConfig.NightModeStartHour:00</small>
                    </div>

                    <div class="setting-item">
                        <label>End Hour (24h format)</label>
                        <input type="number" min="0" max="23" @bind="SystemConfig.NightModeEndHour" @bind:after="SaveSettings" class="form-input" />
                        <small>Watering allowed until @SystemConfig.NightModeEndHour:00</small>
                    </div>
                }
            </div>
        </div>

        <div class="settings-section">
            <h4>Eco Mode</h4>
            
            <div class="setting-item">
                <label class="toggle-label">
                    <input type="checkbox" @bind="SystemConfig.EcoModeEnabled" @bind:after="SaveSettingsImmediate" class="toggle-input" />
                    <span class="toggle-slider-sm"></span>
                    <span class="toggle-text">Enable Eco Mode</span>
                </label>
                <small>Reduce watering frequency to conserve water and battery</small>
            </div>
        </div>
    }

    <div class="settings-section">
        <h4>Adaptive Watering AI</h4>
        <p>The adaptive algorithm analyzes irrigation history and automatically adjusts moisture thresholds for optimal watering.</p>
        
        <button class="btn-primary" @onclick="RunAdaptiveAnalysis" disabled="@IsRunning">
            @if (IsRunning)
            {
                <span>⏳ Running Analysis...</span>
            }
            else
            {
                <span>▶️ Run Adaptive Analysis Now</span>
            }
        </button>

        @if (AnalysisComplete)
        {
            <div class="success-message">✓ Analysis complete! Check logs below for threshold changes.</div>
        }
    </div>

    <div class="settings-section">
        <h4>AI Decision Management</h4>

        @if (AiConfig == null)
        {
            <p>Loading AI settings...</p>
        }
        else
        {
            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Decision AI:</span>
                    <span class="info-value">@(AiConfig.EnableAiDecisionMaking ? "Enabled" : "Disabled")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">API key:</span>
                    <span class="info-value">@GetAiApiKeyStatus()</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Model:</span>
                    <span class="info-value">@AiConfig.Model</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Last decision:</span>
                    <span class="info-value">@GetLatestAiDecisionSummary()</span>
                </div>
                <div class="info-item">
                    <span class="info-label">API test:</span>
                    <span class="info-value">@(LatestAiApiCheck?.IsSuccess == true ? "Passed" : LatestAiApiCheck == null ? "Not tested" : "Failed")</span>
                </div>
            </div>

            @if (!IsAiApiKeyConfigured)
            {
                <div class="warning-message">@GetAiApiKeySource() is not set on this server.</div>
            }

            @if (!string.IsNullOrWhiteSpace(AiSettingsError))
            {
                <div class="warning-message">@AiSettingsError</div>
            }

            <div class="settings-grid mt-2">
                <div class="setting-item">
                    <label class="toggle-label">
                        <input type="checkbox" @bind="AiConfig.EnableAiDecisionMaking" class="toggle-input" />
                        <span class="toggle-slider-sm"></span>
                        <span class="toggle-text">Enable AI Decision Making</span>
                    </label>
                    <small>Sensor readings still use rule fallback when this is off or the API key is missing</small>
                </div>

                <div class="setting-item">
                    <label>OpenAI Model</label>
                    <input type="text" @bind="AiConfig.Model" class="form-input" />
                    <small>Configured model name used for irrigation analysis</small>
                </div>

                <div class="setting-item">
                    <label>API Key Environment Variable Name</label>
                    <input type="text"
                           maxlength="100"
                           placeholder="OPENAI_API_KEY"
                           @bind="AiConfig.ApiKeyEnvironmentVariable"
                           class="form-input" />
                    <small>Put the secret key in PowerShell as OPENAI_API_KEY; this box stores only the variable name</small>
                </div>

                <div class="setting-item">
                    <label>Minimum Minutes Between AI Calls</label>
                    <input type="number" min="0" max="1440" @bind="AiConfig.MinimumMinutesBetweenAiCalls" class="form-input" />
                    <small>Current cooldown: @AiConfig.MinimumMinutesBetweenAiCalls minute(s)</small>
                </div>

                <div class="setting-item">
                    <label>Recent History Window (hours)</label>
                    <input type="number" min="1" max="168" @bind="AiConfig.RecentHistoryHours" class="form-input" />
                    <small>Readings included in the AI prompt</small>
                </div>

                <div class="setting-item">
                    <label>Recent Watering Events</label>
                    <input type="number" min="1" max="100" @bind="AiConfig.RecentWateringEvents" class="form-input" />
                    <small>Watering events included in the AI prompt</small>
                </div>

                <div class="setting-item">
                    <label>Pattern Memory Count</label>
                    <input type="number" min="1" max="50" @bind="AiConfig.PatternMemoryCount" class="form-input" />
                    <small>Saved observations included in each AI prompt</small>
                </div>

                <div class="setting-item">
                    <label>High Moisture Block (%)</label>
                    <input type="number" min="0" max="100" step="0.5" @bind="AiConfig.HighMoistureBlockPercent" class="form-input" />
                    <small>Watering is blocked at or above @AiConfig.HighMoistureBlockPercent.ToString("F1")%</small>
                </div>

                <div class="setting-item">
                    <label>Low Confidence Threshold</label>
                    <input type="number" min="0" max="1" step="0.05" @bind="AiConfig.LowConfidenceThreshold" class="form-input" />
                    <small>Fallback rules are used below @AiConfig.LowConfidenceThreshold.ToString("F2") confidence</small>
                </div>

                <div class="setting-item">
                    <label>Max AI Watering Duration (seconds)</label>
                    <input type="number" min="1" max="3600" @bind="AiConfig.MaxDurationSeconds" class="form-input" />
                    <small>AI recommendations are clamped to this limit</small>
                </div>

                <div class="setting-item">
                    <label>Minimum Minutes Between Waterings</label>
                    <input type="number" min="0" max="1440" @bind="AiConfig.MinimumMinutesBetweenWaterings" class="form-input" />
                    <small>Safety cooldown between watering events for a zone</small>
                </div>

                <div class="setting-item">
                    <label>Fallback Duration (seconds)</label>
                    <input type="number" min="1" max="3600" @bind="AiConfig.DefaultFallbackDurationSeconds" class="form-input" />
                    <small>Rule-based duration when AI is unavailable</small>
                </div>
            </div>

            <div class="settings-actions">
                <button class="btn-primary" @onclick="SaveAiSettings" disabled="@IsSavingAiSettings">
                    @(IsSavingAiSettings ? "Saving AI Settings..." : "Save AI Settings")
                </button>
                <button class="btn-warning" @onclick="TestAiApi" disabled="@IsTestingAiApi">
                    @(IsTestingAiApi ? "Testing OpenAI API..." : "Test OpenAI API")
                </button>
                <button class="btn-secondary" @onclick="LoadAiSettings">Refresh AI Status</button>
            </div>

            @if (AiSettingsSaved)
            {
                <div class="success-message">AI settings saved.</div>
            }

            @if (LatestAiApiCheck != null)
            {
                <div class="@(LatestAiApiCheck.IsSuccess ? "success-message" : "warning-message")">
                    @LatestAiApiCheck.CheckedAt.ToString("HH:mm:ss") - @LatestAiApiCheck.Message
                    @if (LatestAiApiCheck.RetryAfter.HasValue && LatestAiApiCheck.RetryAfter.Value > DateTime.Now)
                    {
                        <span> Next automatic retry after @LatestAiApiCheck.RetryAfter.Value.ToString("HH:mm").</span>
                    }
                </div>
            }
        }
    </div>

    <div class="settings-section">
        <h4>Database Maintenance</h4>
        <p>Clean up old sensor readings to save storage space</p>
        
        <div class="cleanup-controls">
            <label>Keep data from last:</label>
            <select @bind="DaysToKeep" class="form-input-inline">
                <option value="7">7 days</option>
                <option value="14">14 days</option>
                <option value="30">30 days</option>
                <option value="60">60 days</option>
                <option value="90">90 days</option>
            </select>
            
            <button class="btn-warning" @onclick="CleanDatabase" disabled="@IsCleaning">
                @if (IsCleaning)
                {
                    <span>🗑️ Cleaning...</span>
                }
                else
                {
                    <span>🗑️ Clean Old Data</span>
                }
            </button>
        </div>

        @if (CleanupComplete)
        {
            <div class="success-message">✓ Deleted @DeletedRecords old sensor readings</div>
        }
    </div>

    <div class="settings-section">
        <h4>Recent System Logs</h4>
        
        @if (IsLoadingLogs)
        {
            <p>Loading logs...</p>
        }
        else if (SystemLogs.Count == 0)
        {
            <p>No logs yet.</p>
        }
        else
        {
            <div class="logs-container">
                @foreach (var log in SystemLogs)
                {
                    <div class="log-entry @log.Level.ToLower()">
                        <span class="log-time">@log.LoggedAt.ToString("MM/dd HH:mm:ss")</span>
                        <span class="log-level">[@log.Level]</span>
                        <span class="log-message">@log.Message</span>
                    </div>
                }
            </div>
        }

        <button class="btn-secondary" @onclick="LoadLogs">🔄 Refresh Logs</button>
    </div>

    <div class="settings-section">
        <h4>Demo Mode</h4>
        <p>Use simulated sensor readings instead of real hardware.</p>

        <button class="btn-secondary" @onclick="ToggleDemoMode">
            @if (IsDemoMode)
            {
                <span>🛑 Disable Demo Mode</span>
            }
            else
            {
                <span>▶️ Enable Demo Mode</span>
            }
        </button>

        @if (IsDemoMode)
        {
            <div class="success-message mt-2">🎭 Demo mode is currently <strong>enabled</strong>.</div>
        }
    </div>

    <div class="settings-section">
        <h4>System Information</h4>
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">Total Zones:</span>
                <span class="info-value">3</span>
            </div>
            <div class="info-item">
                <span class="info-label">Database:</span>
                <span class="info-value">PostgreSQL</span>
            </div>
            <div class="info-item">
                <span class="info-label">MQTT Broker:</span>
                <span class="info-value">Mosquitto</span>
            </div>
            <div class="info-item">
                <span class="info-label">Auto-refresh:</span>
                <span class="info-value">5 seconds</span>
            </div>
        </div>
    </div>
</div>

@code {
    private SystemSettings? SystemConfig;
    private AiIrrigationOptions? AiConfig;
    private AiIrrigationDecisionLog? LatestAiDecision;
    private AiApiCheckResult? LatestAiApiCheck;
    private List<SystemLog> SystemLogs = new();
    
    private bool IsLoadingLogs = true;
    private bool IsRunning = false;
    private bool AnalysisComplete = false;
    private bool IsCleaning = false;
    private bool CleanupComplete = false;
    private bool IsSavingAiSettings = false;
    private bool IsTestingAiApi = false;
    private bool AiSettingsSaved = false;
    private string? AiSettingsError;

    private bool IsDemoMode = false;

    private int DaysToKeep = 30;
    private int DeletedRecords = 0;
    
    private System.Threading.Timer? SaveTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
        await LoadAiSettings();
        await LoadLogs();

        IsDemoMode = DemoService.IsDemoMode;
    }

    public void Dispose()
    {
        SaveTimer?.Dispose();
    }

    private async Task LoadSettings()
    {
        SystemConfig = await DataService.GetSystemSettingsAsync();
        if (SystemConfig == null)
        {
            SystemConfig = new SystemSettings();
        }
    }

    private async Task LoadAiSettings()
    {
        AiConfig = await DataService.GetAiIrrigationOptionsAsync(AiDefaults.Value);
        LatestAiDecision = await DataService.GetLatestAiDecisionAsync();
        LatestAiApiCheck = AiApiHealth.GetLastResult();
    }

    private bool IsAiApiKeyConfigured =>
        AiConfig != null &&
        ApiKeyProvider.GetApiKey(AiConfig.ApiKeyEnvironmentVariable).IsConfigured;

    private string GetAiApiKeyStatus()
    {
        if (AiConfig == null)
        {
            return "Unknown";
        }

        var lookup = ApiKeyProvider.GetApiKey(AiConfig.ApiKeyEnvironmentVariable);
        return lookup.IsConfigured ? $"Configured ({lookup.Source})" : "Missing";
    }

    private string GetAiApiKeySource()
    {
        if (AiConfig == null)
        {
            return "OpenAI API key";
        }

        return ApiKeyProvider.GetApiKey(AiConfig.ApiKeyEnvironmentVariable).Source;
    }

    private string GetLatestAiDecisionSummary()
    {
        if (LatestAiDecision == null)
        {
            return "No decisions";
        }

        var mode = LatestAiDecision.AiWasAttempted ? "AI" : "Fallback";
        return $"{mode} {LatestAiDecision.Timestamp:MM/dd HH:mm}";
    }

    private async Task SaveAiSettings()
    {
        if (AiConfig == null)
        {
            return;
        }

        IsSavingAiSettings = true;
        AiSettingsSaved = false;
        AiSettingsError = null;

        if (LooksLikeSecretApiKey(AiConfig.ApiKeyEnvironmentVariable))
        {
            AiConfig.ApiKeyEnvironmentVariable = "OPENAI_API_KEY";
            AiSettingsError = "That field is only for the environment variable name. Put the actual secret key in PowerShell as OPENAI_API_KEY, then restart the web app.";
            IsSavingAiSettings = false;
            return;
        }

        if (AiConfig.ApiKeyEnvironmentVariable.Length > 100)
        {
            AiSettingsError = "Environment variable names must be short. Use OPENAI_API_KEY here and put the long secret key in PowerShell.";
            IsSavingAiSettings = false;
            return;
        }

        try
        {
            if (await DataService.UpdateAiIrrigationOptionsAsync(AiConfig))
            {
                await LoadAiSettings();
                await LoadLogs();
                AiSettingsSaved = true;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(2500);
                AiSettingsSaved = false;
            }
        }
        finally
        {
            IsSavingAiSettings = false;
        }
    }

    private async Task TestAiApi()
    {
        if (AiConfig == null)
        {
            return;
        }

        IsTestingAiApi = true;
        AiSettingsError = null;

        try
        {
            LatestAiApiCheck = await AiApiHealth.CheckAsync(AiConfig);
            await LoadLogs();
        }
        finally
        {
            IsTestingAiApi = false;
        }
    }

    private static bool LooksLikeSecretApiKey(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var trimmed = value.Trim();
        return trimmed.StartsWith("sk-", StringComparison.OrdinalIgnoreCase) ||
               trimmed.StartsWith("sk_", StringComparison.OrdinalIgnoreCase);
    }

    private async Task SaveSettingsImmediate()
    {
        if (SystemConfig != null)
        {
            await DataService.UpdateSystemSettingsAsync(SystemConfig);
            await LoadLogs();
        }
    }

    private void SaveSettings()
    {
        SaveTimer?.Dispose();
        SaveTimer = new System.Threading.Timer(async _ =>
        {
            if (SystemConfig != null)
            {
                await DataService.UpdateSystemSettingsAsync(SystemConfig);
            }
        }, null, 500, Timeout.Infinite);
    }

    private async Task LoadLogs()
    {
        IsLoadingLogs = true;
        SystemLogs = await DataService.GetRecentLogsAsync(20);
        IsLoadingLogs = false;
    }

    private async Task ToggleDemoMode()
    {
        if (IsDemoMode)
        {
            DemoService.DisableDemoMode();
            IsDemoMode = false;
        }
        else
        {
            DemoService.EnableDemoMode();
            IsDemoMode = true;
        }

        await LoadLogs();
    }

    private async Task RunAdaptiveAnalysis()
    {
        IsRunning = true;
        AnalysisComplete = false;

        try
        {
            await AdaptiveService.RunAdaptiveAnalysisAsync();
            await Task.Delay(1000);
            await LoadLogs();
            AnalysisComplete = true;
            await Task.Delay(3000);
            AnalysisComplete = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            IsRunning = false;
        }
    }

    private async Task CleanDatabase()
    {
        IsCleaning = true;
        CleanupComplete = false;

        try
        {
            DeletedRecords = await DataService.CleanOldDataAsync(DaysToKeep);
            CleanupComplete = true;
            await Task.Delay(3000);
            CleanupComplete = false;
        }
        finally
        {
            IsCleaning = false;
        }
    }
}
